# Kopiere diese Datei nach .streamlit/secrets.toml und trage den echten Key ein.
# Lokal:   app/.streamlit/secrets.toml
# Cloud:   Streamlit Community Cloud → App → Settings → Secrets (Inhalt hier einfügen)

ANTHROPIC_API_KEY = "sk-ant-..."

# Optional: Zugangsschutz, damit nur Kunden mit Passwort die App nutzen können.
# Leer lassen = kein Passwortschutz.
APP_PASSWORD = ""
